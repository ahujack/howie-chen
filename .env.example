# Vercel / 本地 vercel dev：在面板或 .env.local 中配置（勿提交真实密钥）
DEEPSEEK_API_KEY=
TAVILY_API_KEY=

# Postgres（计费 / 管理后台 / 人设；Neon 等）
# DATABASE_URL=

# 生产环境要求所有 /api/chat 请求携带 X-API-Key（sk_…）；未配置数据库时勿开启
# REQUIRE_API_KEY=true

# 管理后台（/admin）：密码 + 用于签发会话的密钥（≥16 字符）
# ADMIN_SECRET 同时用于加密保存 API Key 密文（管理端「眼睛」解密展示）；勿随意更换，否则旧备份无法解密
# ADMIN_PASSWORD=
# ADMIN_SECRET=

# 积分：每多少 tokens 扣 1 分（默认 100）；新户默认赠送积分（默认 10000，约对应 100 万 tokens 折算）
# TOKENS_PER_POINT=100
# DEFAULT_GRANT_POINTS=10000

# 仅展示用：粗算「每百万 tokens 约多少元人民币」用于 /api/billing-me 返回给前端（非扣费逻辑）
# ESTIMATE_CNY_PER_MILLION_TOKENS=2

# 仅本地 npm run dev：设为 true 时用本地规则假回复（勿在 Vercel 生产环境配置，否则会打进构建产物）
# VITE_USE_LOCAL_CHAT=true

# 未填计费 API Key 时，前端允许免费对话轮次（每次成功完成一轮计 1；填 Key 后走积分，不再计次）
# VITE_FREE_CHAT_ROUNDS=10
