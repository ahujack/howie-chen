{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/chat.js": {
      "maxDuration": 60,
      "includeFiles": "api/kb-howie-content.md"
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/persona.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
