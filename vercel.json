{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/chat.js": {
      "maxDuration": 60,
      "includeFiles": "api/kb-*.md"
    },
    "api/health.js": {
      "maxDuration": 10
    },
    "api/persona.js": {
      "maxDuration": 30
    },
    "api/hot-trends.js": {
      "maxDuration": 30
    },
    "api/billing-me.js": {
      "maxDuration": 15
    },
    "api/admin-login.js": {
      "maxDuration": 15
    },
    "api/admin-accounts.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
